`define TRACE(msg) class'EIR_Logger'.static.Trace(class'EIR_Logger'.static.PadFuncName(string(GetFuncName())) $ ":" @ `msg)
`define DEBUG(msg) class'EIR_Logger'.static.Debug(class'EIR_Logger'.static.PadFuncName(string(GetFuncName())) $ ":" @ `msg)
`define INFO(msg)  class'EIR_Logger'.static.Info(class'EIR_Logger'.static.PadFuncName(string(GetFuncName())) $ ":" @ `msg)
`define WARN(msg)  class'EIR_Logger'.static.Warn(class'EIR_Logger'.static.PadFuncName(string(GetFuncName())) $ ":" @ `msg)
`define ERROR(msg) class'EIR_Logger'.static.Error(class'EIR_Logger'.static.PadFuncName(string(GetFuncName())) $ ":" @ `msg)